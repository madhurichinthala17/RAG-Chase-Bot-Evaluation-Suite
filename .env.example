# Environment Configuration for RAG Chase-bot Evaluation Suite

# ============================================================================
# REQUIRED: DeepEval / Confident AI
# ============================================================================
# Your Confident AI API key for DeepEval integration
# Get it from: https://app.confident-ai.com/settings
CONFIDENT_API_KEY=your_confident_api_key_here

# Enable trace flushing (sends traces to Confident AI in real-time)
# Set to 1 to enable, 0 or omit to disable
CONFIDENT_TRACE_FLUSH=1

# ============================================================================
# REQUIRED: OpenAI (for optional tracing & debugging)
# ============================================================================
# Your OpenAI API key (for trace logging and analysis)
# Get it from: https://platform.openai.com/api-keys
# If you don't want tracing, you can omit this, but some features may break
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# OPTIONAL: Ollama Configuration
# ============================================================================
# Ollama host (default: http://localhost:11434 if running locally)
# Change this if Ollama is running on a different machine
# OLLAMA_HOST=http://localhost:11434

# Ollama LLM model (must be available via `ollama pull <model>`)
# Default: qwen2.5:latest
# Other options: mistral:latest, llama2:latest, neural-chat:latest
# OLLAMA_MODEL=qwen2.5:latest

# Ollama embedding model (must be available via `ollama pull <model>`)
# Default: nomic-embed-text:latest
# OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ============================================================================
# OPTIONAL: Document Configuration
# ============================================================================
# Path to the PDF document to evaluate
# Default: data/raw_docs/JPmorgan10kReport.pdf
# PDF_PATH=data/raw_docs/JPmorgan10kReport.pdf

# ============================================================================
# OPTIONAL: Evaluation Configuration
# ============================================================================
# Path to experiment config (defines retrieval strategy, chunk size, etc.)
# Default: evaluation/configs/final.yaml
# CONFIG_PATH=evaluation/configs/final.yaml

# ============================================================================
# OPTIONAL: Vector Store Configuration
# ============================================================================
# Path to Chroma vector store (SQLite backend)
# Default: data/vectorstores/chroma_langchain_db/
# CHROMA_DB_PATH=data/vectorstores/chroma_langchain_db/

# ============================================================================
# OPTIONAL: Logging & Debugging
# ============================================================================
# Set to 1 to enable verbose logging, 0 for quiet mode
# DEBUG=0

# ============================================================================
# OPTIONAL: External Service Configuration
# ============================================================================
# If using a cloud LLM (e.g., OpenAI, Anthropic), set these:
# ANTHROPIC_API_KEY=your_anthropic_key_here
# COHERE_API_KEY=your_cohere_key_here

# ============================================================================
# Quick Start Checklist
# ============================================================================
# 1. Get CONFIDENT_API_KEY from https://app.confident-ai.com/settings
# 2. Get OPENAI_API_KEY from https://platform.openai.com/api-keys
# 3. Ensure Ollama is running: `ollama serve` in another terminal
# 4. Pull required models: `ollama pull qwen2.5:latest nomic-embed-text`
# 5. Fill in the REQUIRED fields above
# 6. Run: python evaluation/pipelines/runner.py
